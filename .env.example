# Environment configuration template
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=openai          # openai | google | anthropic
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
TEMPERATURE=0.3

# ── Search / Retrieval ────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── MongoDB (corpus) ──────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=revisao_agents

# ── LangGraph persistence ─────────────────────────────────────────────────────
CHECKPOINT_TYPE=memory       # memory | sqlite | postgres
# CHECKPOINT_DB_PATH=checkpoints.db          # for sqlite
# CHECKPOINT_POSTGRES_URI=postgresql://...   # for postgres

# ── Paths ─────────────────────────────────────────────────────────────────────
PROMPTS_DIR=prompts/technical_writing
